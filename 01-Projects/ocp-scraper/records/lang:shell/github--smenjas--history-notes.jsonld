  "@id": "ocp:github/smenjas--history-notes",
  "meta": {
    "title": "A Chronicle of Nature, Science, & Technology",
    "description": "My notes on natural history, science, and technology.",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T21:01:35.265Z",
