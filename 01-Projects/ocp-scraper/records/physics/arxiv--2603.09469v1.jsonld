  "@type": "SolutionRecord",
  "@id": "ocp:arxiv/2603.09469v1",
  "meta": {
    "title": "Phase diagram and Ashkin-Teller universality in the classical square-lattice Heisenberg-compass model",
    "description": "We determine the finite-temperature phase diagram and critical behavior of the classical square-lattice Heisenberg-compass model using large-scale Monte Carlo simulations and finite-size scaling. Six symmetry distinct ordered phases are identified. The four phases that simultaneously break the spin-lattice $C_4$ and in-plane spin-inversion symmetries undergo continuous transitions in the Ashkin-Teller universality class, with the associated critical lines terminating at four-state Potts points, beyond which the transitions become first order. In contrast, the two $z$-polarized phases display conventional two-dimensional Ising criticality. Our results reveal how the interplay between Heisenberg exchange and compass anisotropy organizes these distinct critical regimes, thereby completing the characterization of the model's thermal phase transitions.",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T06:37:44.144Z",
    "dateModified": "2026-03-11T06:37:44.144Z",
    "datePublished": "2026-03-10T10:21:31.000Z",
    "keywords": [
      "cond-mat.str-el",
      "cond-mat.stat-mech"
    ]
  },
  "problemSolved": {
    "statement": "We determine the finite-temperature phase diagram and critical behavior of the classical square-lattice Heisenberg-compass model using large-scale Monte Carlo simulations and finite-size scaling. Six symmetry distinct ordered phases are identified. The four phases that simultaneously break the spin-lattice $C_4$ and in-plane spin-inversion symmetries undergo continuous transitions in the Ashkin-Teller universality class, with the associated critical lines terminating at four-state Potts points, beyond which the transitions become first order. In contrast, the two $z$-polarized phases display conventional two-dimensional Ising criticality. Our results reveal how the interplay between Heisenberg exchange and compass anisotropy organizes these distinct critical regimes, thereby completing the characterization of the model's thermal phase transitions.",
    "context": "arXiv categories: cond-mat.str-el, cond-mat.stat-mech | Phys. Rev. B 113,115114 (2026) | 8 pages, 9 figures",
    "cynefinDomain": "complicated"
  },
