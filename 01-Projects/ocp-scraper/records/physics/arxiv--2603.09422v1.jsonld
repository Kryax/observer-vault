  "@type": "SolutionRecord",
  "@id": "ocp:arxiv/2603.09422v1",
  "meta": {
    "title": "Temporal Berry Phase and the Emergence of Bose-Glass-Analog Phase in a Clean U(1) Superfluid",
    "description": "A U(1) nonlinear sigma model (NLSM) with a one-dimensional temporal Berry phase term describes the critical theory of phase-fluctuation-driven superfluid (SF) transitions. We clarify that the temporal Berry phase leads to space-time anisotropic interference in vortex proliferation, resulting in a quasi-disordered phase characterized by short-range spatial order but persistent temporal phase coherence. This phase shares the essential SF phase correlation properties of the Bose Glass phase known from disordered boson systems, suggesting a unified topological origin for the emergence of the glassy phase in phase-fluctuation-driven superfluid transitions.",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T06:37:47.093Z",
    "dateModified": "2026-03-11T06:37:47.093Z",
    "datePublished": "2026-03-10T09:37:21.000Z",
    "keywords": [
      "cond-mat.supr-con",
      "cond-mat.quant-gas",
      "cond-mat.stat-mech",
      "cond-mat.str-el"
    ]
  },
  "problemSolved": {
    "statement": "A U(1) nonlinear sigma model (NLSM) with a one-dimensional temporal Berry phase term describes the critical theory of phase-fluctuation-driven superfluid (SF) transitions. We clarify that the temporal Berry phase leads to space-time anisotropic interference in vortex proliferation, resulting in a quasi-disordered phase characterized by short-range spatial order but persistent temporal phase coherence. This phase shares the essential SF phase correlation properties of the Bose Glass phase known from disordered boson systems, suggesting a unified topological origin for the emergence of the glassy phase in phase-fluctuation-driven superfluid transitions.",
    "context": "arXiv categories: cond-mat.supr-con, cond-mat.quant-gas, cond-mat.stat-mech, cond-mat.str-el | 5 pages, 3 figures with supplemental materials",
