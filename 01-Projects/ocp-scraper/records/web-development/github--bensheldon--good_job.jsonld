  "@id": "ocp:github/bensheldon--good_job",
  "meta": {
    "title": "GoodJob",
    "description": "Multithreaded, Postgres-based, Active Job backend for Ruby on Rails.",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T06:58:58.782Z",
    "dateModified": "2026-03-22T06:58:58.782Z",
    "keywords": [
