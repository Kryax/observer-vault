  "@id": "ocp:github/nolar--kopf",
  "meta": {
    "title": "Kubernetes Operator Pythonic Framework (Kopf)",
    "description": "A Python framework to write Kubernetes operators in just a few lines of code",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:48:20.286Z",
