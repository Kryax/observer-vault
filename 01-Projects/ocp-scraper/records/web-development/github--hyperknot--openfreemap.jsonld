  "@id": "ocp:github/hyperknot--openfreemap",
  "meta": {
    "title": "OpenFreeMap",
    "description": "Free and open-source map hosting solution with custom styles for websites and apps, using OpenStreetMap data",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:47:57.655Z",
    "dateModified": "2026-03-11T04:47:57.655Z",
    "keywords": [
      "geospatial",
      "gis",
      "maplibre",
      "maplibre-gl-js",
      "mapping",
      "maps",
      "openstreetmap",
      "osm",
      "vector-tiles"
    ],
    "license": "NOASSERTION"
  },
  "problemSolved": {
    "statement": "OpenFreeMap lets you display custom maps on your website and apps for free.",
    "context": "OpenFreeMap lets you display custom maps on your website and apps for free.\n\nYou can either [self-host](docs/self_hosting.md) or use our public instance. Everything is **open-source**, including the full production setup — there’s no 'open-core' model here. The map data comes from OpenStreetMap.\n\nUsing our **public instance** is completely free: there are no limits on the number of map views or requests. There’s no registration, no user database, no API keys, and no cookies. We aim to cover the running costs of our public instance through donations.\n\nWe also provide **weekly** full planet downloads both in Btrfs and MBTiles formats.",
    "cynefinDomain": "complex"
  },
