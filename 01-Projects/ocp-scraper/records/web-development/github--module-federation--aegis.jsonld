  "@id": "ocp:github/module-federation--aegis",
  "meta": {
    "title": "ÆGIS",
    "description": "Module federation for the backend. Aegis core lib. Regain control of your microservices by consolidating them into one or more shared processes without loosing deployment or language independence. Eliminate the need for deployment automation. Let services deploy themselves. ",
    "version": "1.0.0",
    "dateCreated": "2026-03-23T06:21:59.457Z",
    "dateModified": "2026-03-23T06:21:59.457Z",
