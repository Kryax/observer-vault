  "meta": {
    "title": "Veramo",
    "description": "A JavaScript Framework for Verifiable Data",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:44:44.803Z",
    "dateModified": "2026-03-11T04:44:44.803Z",
    "keywords": [
