  "@id": "ocp:github/teamhanko--hanko",
  "meta": {
    "title": "About Hanko",
    "description": "Modern authentication, on your terms. Open source alternative to Auth0, Clerk, WorkOS, Stytch.",
    "version": "1.0.0",
