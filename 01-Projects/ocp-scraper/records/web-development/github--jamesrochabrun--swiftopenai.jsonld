  "@id": "ocp:github/jamesrochabrun--swiftopenai",
  "meta": {
    "title": "SwiftOpenAI",
    "description": "The most complete open-source Swift package for interacting with OpenAI's public API.",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T06:18:56.440Z",
    "dateModified": "2026-03-22T06:18:56.440Z",
    "keywords": [
