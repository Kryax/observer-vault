  "problemSolved": {
    "statement": "Rclone *(\"rsync for cloud storage\")* is a command-line program to sync files and\ndirectories to and from different cloud storage providers.",
    "context": "Rclone *(\"rsync for cloud storage\")* is a command-line program to sync files and\ndirectories to and from different cloud storage providers.",
