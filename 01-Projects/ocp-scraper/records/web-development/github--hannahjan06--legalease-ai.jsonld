  "@id": "ocp:github/hannahjan06--legalease-ai",
  "meta": {
    "title": "LegalEase-AI",
    "description": "LegalEase AI is a document simplification tool built using Gemini API, Streamlit, and Hugging Face models. It allows users to upload legal PDFs and automatically receive simplified summaries, clause-level insights, and structured information designed for clarity and accessibility.",
    "version": "1.0.0",
