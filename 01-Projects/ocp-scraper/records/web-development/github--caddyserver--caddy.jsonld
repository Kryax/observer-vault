  "@id": "ocp:github/caddyserver--caddy",
  "meta": {
    "title": "caddy",
    "description": "Fast and extensible multi-platform HTTP/1-2-3 web server with automatic HTTPS",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:47:11.378Z",
    "dateModified": "2026-03-11T04:47:11.378Z",
    "keywords": [
      "acme",
      "automatic-https",
      "caddy",
      "caddyfile",
      "go",
      "golang",
      "http",
      "http-server",
      "http3",
      "https",
      "privacy",
      "reverse-proxy",
      "security",
      "tls",
      "web-server"
    ],
    "license": "Apache-2.0"
  },
  "problemSolved": {
    "statement": "Caddy is most often used as an HTTPS server, but it is suitable for any long-running Go program. First and foremost, it is a platform to run Go applications. Caddy \"apps\" are just Go programs that are implemented as Caddy modules. Two apps -- `tls` and `http` -- ship standard with Caddy.",
    "cynefinDomain": "complex"
  },
