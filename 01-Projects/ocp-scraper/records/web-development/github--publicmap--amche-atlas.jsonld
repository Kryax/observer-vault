  "@id": "ocp:github/publicmap--amche-atlas",
  "meta": {
    "title": "amche-atlas",
    "description": "A lightweight and customizable web GIS platform for the state of Goa, India. Designed as a community maintained tool for hyperlocal spatial data exploration and decision making.",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:23:15.563Z",
    "dateModified": "2026-03-11T04:23:15.563Z",
    "keywords": [
