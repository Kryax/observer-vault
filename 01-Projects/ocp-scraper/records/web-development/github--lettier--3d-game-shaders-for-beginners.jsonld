  "@id": "ocp:github/lettier--3d-game-shaders-for-beginners",
  "meta": {
    "title": "3D Game Shaders For Beginners",
    "description": "🎮 A step-by-step guide to implementing SSAO, depth of field, lighting, normal mapping, and more for your 3D game.",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:21:32.029Z",
    "dateModified": "2026-03-11T04:21:32.029Z",
