  "meta": {
    "title": "Web Engineering and Technologies Project: CaseAce Backend",
    "description": "CaseAce - A backend solution for case and staff management in law firms, built with Node.js and Express",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T10:27:27.838Z",
