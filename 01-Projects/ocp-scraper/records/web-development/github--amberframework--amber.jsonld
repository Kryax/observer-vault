  "@id": "ocp:github/amberframework--amber",
  "meta": {
    "title": "Welcome to Amber",
    "description": "A Crystal web framework that makes building applications fast, simple, and enjoyable. Get started with quick prototyping, less bugs, and blazing fast performance.",
