  "@id": "ocp:github/cesiumgs--cesium",
  "meta": {
    "title": "CesiumJS",
    "description": "An open-source JavaScript library for world-class 3D globes and maps :earth_americas:",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:46:59.608Z",
