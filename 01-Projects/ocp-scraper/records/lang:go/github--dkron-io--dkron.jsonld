  "@id": "ocp:github/dkron-io--dkron",
  "meta": {
    "title": "Dkron - Distributed, fault tolerant job scheduling system for cloud native environments [![GoDoc](https://godoc.org/github.com/distribworks/dkron?status.svg)](https://godoc.org/github.com/distribworks/dkron) [![Actions Status](https://github.com/distribworks/dkron/workflows/Test/badge.svg)](https://github.com/distribworks/dkron/actions) [![Gitter](https://badges.gitter.im/distribworks/dkron.svg)](https://gitter.im/distribworks/dkron) [![Gurubase](https://img.shields.io/badge/Gurubase-Ask%20Dkron%20Guru-006BFF)](https://gurubase.io/g/dkron)",
    "description": "Dkron - Distributed, fault tolerant job scheduling system https://dkron.io",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T20:59:48.024Z",
    "dateModified": "2026-03-10T20:59:48.024Z",
