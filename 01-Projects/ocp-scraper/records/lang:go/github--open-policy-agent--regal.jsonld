  "meta": {
    "title": "Regal",
    "description": "Regal is a linter and language server for Rego, bringing your policy development experience to the next level!",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:50:34.831Z",
    "dateModified": "2026-03-11T04:50:34.831Z",
    "keywords": [
