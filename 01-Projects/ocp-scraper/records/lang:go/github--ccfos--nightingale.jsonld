  "meta": {
    "title": "nightingale",
    "description": "Nightingale is to monitoring and alerting what Grafana is to visualization.",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T08:43:48.155Z",
    "dateModified": "2026-03-03T08:43:48.155Z",
