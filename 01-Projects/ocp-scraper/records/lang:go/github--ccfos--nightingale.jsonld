    ],
    "license": "Apache-2.0"
  },
  "problemSolved": {
    "statement": "Nightingale is an open-source monitoring project that focuses on alerting. Similar to Grafana, Nightingale also connects with various existing data sources. However, while Grafana emphasizes visualization, Nightingale places greater emphasis on the alerting engine, as well as the processing and distribution of alarms.",
    "cynefinDomain": "complex"
  },
