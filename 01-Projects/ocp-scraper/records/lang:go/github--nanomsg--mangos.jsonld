  "@id": "ocp:github/nanomsg--mangos",
  "meta": {
    "title": "mangos&trade; v3",
    "description": "mangos is a pure Golang implementation of nanomsg's \"Scalablilty Protocols\"",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T08:43:17.655Z",
    "dateModified": "2026-03-03T08:43:17.655Z",
    "keywords": [
