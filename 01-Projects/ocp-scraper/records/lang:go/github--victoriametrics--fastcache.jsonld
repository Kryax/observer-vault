  "@id": "ocp:github/victoriametrics--fastcache",
  "meta": {
    "title": "fastcache - fast thread-safe inmemory cache for big number of entries in Go",
    "description": "Fast thread-safe inmemory cache for big number of entries in Go. Minimizes GC overhead",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T07:03:53.378Z",
    "dateModified": "2026-03-03T07:03:53.378Z",
    "keywords": [
      "cache",
      "caching",
      "caching-library",
      "fast",
      "go",
      "golang",
      "inmemory-cache"
    ],
    "license": "MIT"
  },
  "problemSolved": {
    "statement": "* `Fastcache` is faster. See benchmark results above.\n* `Fastcache` uses less memory due to lower heap fragmentation. This allows\n  saving many GBs of memory on multi-GB caches.\n* `Fastcache` API [is simpler](http://godoc.org/github.com/VictoriaMetrics/fastcache).\n  The API is designed to be used in zero-allocation mode.",
    "cynefinDomain": "complex"
  },
