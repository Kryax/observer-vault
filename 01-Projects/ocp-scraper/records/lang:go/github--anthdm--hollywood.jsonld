  "meta": {
    "title": "Blazingly fast, low latency actors for Golang",
    "description": "Blazingly fast and light-weight Actor engine written in Golang",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T21:00:03.456Z",
    "dateModified": "2026-03-10T21:00:03.456Z",
