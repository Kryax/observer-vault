  "@id": "ocp:github/cosmian--kms",
  "meta": {
    "title": "Cosmian KMS",
    "description": "A feature-rich, scalable, Key Management System",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:44:57.491Z",
    "dateModified": "2026-03-11T04:44:57.491Z",
    "keywords": [
