  "@id": "ocp:github/hwdsl2--setup-ipsec-vpn",
  "meta": {
    "title": "IPsec VPN Server Auto Setup Scripts",
    "description": "Scripts to build your own IPsec VPN server, with IPsec/L2TP, Cisco IPsec and IKEv2",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:50:21.710Z",
    "dateModified": "2026-03-11T04:50:21.710Z",
