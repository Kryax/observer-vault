  "@id": "ocp:github/gyulyvgc--sniffnet",
  "meta": {
    "title": "sniffnet",
    "description": "Comfortably monitor your Internet traffic 🕵️‍♂️",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:49:57.784Z",
    "dateModified": "2026-03-11T04:49:57.784Z",
    "keywords": [
