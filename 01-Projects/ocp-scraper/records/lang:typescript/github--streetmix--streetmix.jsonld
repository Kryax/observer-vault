  "@type": "SolutionRecord",
  "@id": "ocp:github/streetmix--streetmix",
  "meta": {
    "title": "streetmix",
    "description": "Streetmix makes it easy for people to design public spaces together.",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:47:07.496Z",
    "dateModified": "2026-03-11T04:47:07.496Z",
    "keywords": [
      "city-builder",
      "city-planning",
      "civic-tech",
      "hacktoberfest",
      "streetmix",
      "urban-planning"
    ],
    "license": "NOASSERTION"
  },
  "problemSolved": {
    "statement": "When city planners seek input from community meetings from the public on streetscape improvements, one common engagement activity is to create paper cut-outs depicting different street components (like bike lanes, sidewalks, trees, and so on) and allow attendees to reassemble them into their desired streetscape. Planners and city officials can then take this feedback to determine a course of action for future plans. By creating an web-based version of this activity, planners can reach a wider audience than they could at meetings alone, and allow community members to share and remix each other's creations.",
    "cynefinDomain": "complex"
  },
  "domains": [
    "lang:typescript"
  ],
