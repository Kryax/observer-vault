  "@id": "ocp:github/packtpublishing--microservices-with-spring-boot-and-spring-cloud-third-edition",
  "meta": {
    "title": "Microservices with Spring Boot 3 and Spring Cloud, Third Edition",
    "description": "Microservices with Spring Boot and Spring Cloud, Third Edition",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T21:01:49.232Z",
    "dateModified": "2026-03-10T21:01:49.232Z",
    "keywords": [],
    "license": "MIT"
