  "meta": {
    "title": "MSS (Marine Systems Simulator)",
    "description": "The Marine Systems Simulator (MSS) is software that supplements the textbook \"Handbook of Marine Craft Hydrodynamics and Motion Control,\" 2nd Edition, by T. I. Fossen, published in 2021 by John Wiley & Sons Ltd.",
    "version": "1.0.0",
