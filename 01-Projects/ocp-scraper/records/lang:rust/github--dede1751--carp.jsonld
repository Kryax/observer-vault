  "@id": "ocp:github/dede1751--carp",
  "meta": {
    "title": "<div align=\"center\"> Carp </div>",
    "description": "Rust didactic UCI chess engine",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T02:50:32.515Z",
    "dateModified": "2026-03-22T02:50:32.515Z",
    "keywords": [
