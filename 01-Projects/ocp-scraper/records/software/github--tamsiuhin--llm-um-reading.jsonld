  "meta": {
    "title": "Large Language Models for User Modeling (LLM-UM) Reading List",
    "description": "A list of large language models for user modeling (LLM-UM) papers, based on \"User Modeling in the Era of Large Language Models: Current Research and Future Directions\" at DEBULL",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T07:15:48.501Z",
