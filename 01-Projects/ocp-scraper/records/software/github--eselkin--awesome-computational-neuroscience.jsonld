  "meta": {
    "title": "Awesome Computational Neuroscience [![Awesome](https://awesome.re/badge.svg)](https://awesome.re)",
    "description": "A list of schools and researchers in computational neuroscience",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T02:49:04.192Z",
    "dateModified": "2026-03-22T02:49:04.192Z",
