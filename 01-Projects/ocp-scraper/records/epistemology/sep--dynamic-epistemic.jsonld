  "@id": "ocp:sep/dynamic-epistemic",
  "meta": {
    "title": "Dynamic Epistemic Logic",
    "description": "Dynamic Epistemic Logic is the study of modal logics of model change. DEL (pronounced \"dell\") is a highly active area of applied logic that touches on topics in many areas, including Formal and Social Epistemology, Epistemic and Doxastic Logic, Belief Revision, multi-agent and distributed systems, Artificial Intelligence, Defeasible and Non-monotonic Reasoning, and Epistemic Game Theory. This article surveys DEL, identifying along the way a number of open questions and natural directions for further research.",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T07:29:58.453Z",
    "dateModified": "2026-03-22T07:29:58.453Z",
    "datePublished": "2016-06-23T14:00:00.000Z",
