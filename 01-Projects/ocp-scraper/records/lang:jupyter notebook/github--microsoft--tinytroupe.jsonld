  "@id": "ocp:github/microsoft--tinytroupe",
  "meta": {
    "title": "TinyTroupe 🤠🤓🥸🧐",
    "description": "LLM-powered multiagent persona simulation for imagination enhancement and business insights.",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T06:18:42.242Z",
    "dateModified": "2026-03-22T06:18:42.242Z",
    "keywords": [],
