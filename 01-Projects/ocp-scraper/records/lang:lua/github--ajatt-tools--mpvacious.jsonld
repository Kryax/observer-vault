  "@id": "ocp:github/ajatt-tools--mpvacious",
  "meta": {
    "title": "mpvacious",
    "description": "🍜 Adds mpv keybindings to create Anki cards from movies and TV shows.",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T10:27:35.938Z",
    "dateModified": "2026-03-03T10:27:35.938Z",
    "keywords": [
      "ajatt",
      "anki",
      "anki-cards",
      "flashcards",
      "language-learning",
      "lua",
      "mpv",
      "mpv-script",
      "spaced-repetition",
      "subs2srs",
      "subtitles",
      "yomichan"
    ],
    "license": "GPL-3.0"
  },
  "problemSolved": {
    "statement": "Mpvacious is a user script for [mpv](https://wiki.archlinux.org/title/Mpv)\nthat offers utilities for creating and modifying Anki flashcards from movies and TV shows.\nIt allows you to select subtitle lines, create audio clips and images, and send them to Anki.\nThe script supports secondary subtitles, configurable media formats, and customizable keyboard bindings.\nMpvacious works best with [Goldendict-ng](https://xiaoyifang.github.io/goldendict-ng/) or [Rikaitan](https://rikaitan.ajatt.top/).\nWatch a [📽️ video demonstration](https://ajatt.top/blog/vid/sentence_mining_with_mpvacious.mp4).",
    "context": "Mpvacious is a user script for [mpv](https://wiki.archlinux.org/title/Mpv)\nthat offers utilities for creating and modifying Anki flashcards from movies and TV shows.\nIt allows you to select subtitle lines, create audio clips and images, and send them to Anki.\nThe script supports secondary subtitles, configurable media formats, and customizable keyboard bindings.\nMpvacious works best with [Goldendict-ng](https://xiaoyifang.github.io/goldendict-ng/) or [Rikaitan](https://rikaitan.ajatt.top/).\nWatch a [📽️ video demonstration](https://ajatt.top/blog/vid/sentence_mining_with_mpvacious.mp4).\n\n✨ Ajatt-Tools is looking for **[new contributors](#contributing)**!",
    "cynefinDomain": "complex"
  },
