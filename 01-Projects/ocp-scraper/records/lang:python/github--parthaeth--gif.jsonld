  "@id": "ocp:github/parthaeth--gif",
  "meta": {
    "title": "GIF: Generative Interpretable Faces",
    "description": "GIF is a photorealistic generative face model with explicit 3D geometric and photometric control.",
    "version": "1.0.0",
    "dateCreated": "2026-03-23T06:28:50.281Z",
    "dateModified": "2026-03-23T06:28:50.281Z",
    "keywords": [
      "conditonal-gan",
      "gan",
      "gans",
      "generative-adversarial-network",
      "generative-interpretable-faces",
      "generative-models",
      "latent-variable-models",
      "photorealism",
      "photorealistic-faces"
    ],
    "license": "MIT"
  },
  "problemSolved": {
    "statement": "This is the official implementation for the paper [GIF: Generative Interpretable Faces](https://arxiv.org/abs/2009.00149).\nGIF is a photorealistic generative face model with explicit control over 3D geometry (parametrized like [FLAME](https://flame.is.tue.mpg.de/)), appearance, and lighting.\n* __Key words:__ _Generative Interpretable Faces, conditional generative models, 3D conditioning of GANs, explicit 3D control of photorealistic faces, Photorealistic faces._",
    "context": "This is the official implementation for the paper [GIF: Generative Interpretable Faces](https://arxiv.org/abs/2009.00149).\nGIF is a photorealistic generative face model with explicit control over 3D geometry (parametrized like [FLAME](https://flame.is.tue.mpg.de/)), appearance, and lighting.\n* __Key words:__ _Generative Interpretable Faces, conditional generative models, 3D conditioning of GANs, explicit 3D control of photorealistic faces, Photorealistic faces._",
    "cynefinDomain": "complex"
  },
