  "@id": "ocp:github/patois--retracker",
  "meta": {
    "title": "RETracker",
    "description": "Reverse Engineering Framework for the Polyend Tracker",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T10:27:40.036Z",
    "dateModified": "2026-03-03T10:27:40.036Z",
    "keywords": [
