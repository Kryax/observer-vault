  "meta": {
    "title": "Differential Dynamic Programming",
    "description": "Differential Dynamic Programming (DDP) with automatic symbolic differentiation",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T05:02:56.529Z",
    "dateModified": "2026-03-10T05:02:56.529Z",
