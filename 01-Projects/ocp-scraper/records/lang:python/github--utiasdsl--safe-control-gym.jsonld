  "@id": "ocp:github/utiasdsl--safe-control-gym",
  "meta": {
    "title": "safe-control-gym",
    "description": "PyBullet CartPole and Quadrotor environments—with CasADi symbolic a priori dynamics—for learning-based control and RL",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T05:02:15.618Z",
    "dateModified": "2026-03-10T05:02:15.618Z",
    "keywords": [
