  "@id": "ocp:github/alexwijn--sat",
  "meta": {
    "title": "Smart Autotune Thermostat",
    "description": "The Smart Autotune Thermostat (SAT) is a custom component for Home Assistant that works with many compatible gateways for your boiler.",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T04:59:48.953Z",
    "dateModified": "2026-03-10T04:59:48.953Z",
    "keywords": [
