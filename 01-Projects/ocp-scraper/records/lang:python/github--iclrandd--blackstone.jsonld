  "@id": "ocp:github/iclrandd--blackstone",
  "meta": {
    "title": "Blackstone [![Built with spaCy](https://img.shields.io/badge/made%20with%20❤%20and-spaCy-09a3d5.svg)](https://spacy.io)",
    "description": ":black_circle: A spaCy pipeline and model for NLP on unstructured legal text.",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:21:28.175Z",
    "dateModified": "2026-03-11T04:21:28.175Z",
    "keywords": [
