  "@id": "ocp:github/silvery107--rl-mpc-locomotion",
  "meta": {
    "title": "RL MPC Locomotion",
    "description": "Deep RL for MPC control of Quadruped Robot Locomotion",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T05:02:13.704Z",
    "dateModified": "2026-03-10T05:02:13.704Z",
    "keywords": [
      "isaac-gym",
