  "@id": "ocp:github/david-cortes--contextualbandits",
  "meta": {
    "title": "Contextual Bandits",
    "description": "Python implementations of contextual bandits algorithms",
    "version": "1.0.0",
    "dateCreated": "2026-03-23T06:33:22.073Z",
    "dateModified": "2026-03-23T06:33:22.073Z",
    "keywords": [
