  "@id": "ocp:github/ssdeanx--branch-thinking-mcp",
  "meta": {
    "title": "🚦 Branch-Thinking MCP Tool",
    "description": "Branch-Thinking MCP Tool A TypeScript-powered MCP server for managing parallel branches of thought, semantic cross-references, and persistent tasks. Features dynamic scoring, AI-generated insights, batch operations, and visual graph navigation for advanced agentic workflows.",
    "version": "1.0.0",
    "dateCreated": "2026-03-09T11:15:33.009Z",
    "dateModified": "2026-03-09T11:15:33.009Z",
