  "@id": "ocp:github/d2l-ai--d2l-zh",
  "meta": {
    "title": "动手学深度学习（Dive into Deep Learning，D2L.ai）",
    "description": "《动手学深度学习》：面向中文读者、能运行、可讨论。中英文版被70多个国家的500多所大学用于教学。",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T02:04:12.402Z",
    "dateModified": "2026-03-11T02:04:12.402Z",
    "keywords": [
      "book",
      "chinese",
      "computer-vision",
      "deep-learning",
      "machine-learning",
      "natural-language-processing",
