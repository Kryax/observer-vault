  "@id": "ocp:github/iml-wg--hepml-livingreview",
  "meta": {
    "title": "**A Living Review of Machine Learning for Particle Physics**",
    "description": "Living Review of Machine Learning for Particle Physics",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T09:33:53.269Z",
    "dateModified": "2026-03-22T09:33:53.269Z",
    "keywords": [
      "hep",
      "latex",
