  "meta": {
    "title": "FlowKit",
    "description": "A Python toolkit for flow cytometry analysis supporting GatingML and FlowJo workspaces",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T09:35:02.205Z",
    "dateModified": "2026-03-11T09:35:02.205Z",
    "keywords": [
