  "meta": {
    "title": "Global Healthy and Sustainable Cities Indicators (GHCSI)",
    "description": "An open-source tool for calculating and reporting spatial indicators for healthy, sustainable cities worldwide using open or custom data.",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:47:12.892Z",
