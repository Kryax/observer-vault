  "@id": "ocp:github/thanos-io--thanos",
  "meta": {
    "title": "thanos",
    "description": "Highly available Prometheus setup with long term storage capabilities. A CNCF Incubating project.",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T08:43:42.964Z",
    "dateModified": "2026-03-03T08:43:42.964Z",
    "keywords": [
      "cncf",
      "go",
      "google-cloud-storage",
      "hacktoberfest",
      "high-availability",
      "metrics",
      "monitoring",
      "observability",
      "prometheus",
      "prometheus-ha-pairs",
      "prometheus-setup",
      "s3",
      "storage",
      "thanos"
    ],
    "license": "Apache-2.0"
  },
  "problemSolved": {
    "statement": "Thanos is a set of components that can be composed into a highly available metric system with unlimited storage capacity, which can be added seamlessly on top of existing Prometheus deployments.",
    "cynefinDomain": "complex"
  },
  "domains": [
    "machine-learning",
    "lang:go"
