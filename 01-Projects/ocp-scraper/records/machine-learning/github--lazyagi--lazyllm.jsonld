  "@id": "ocp:github/lazyagi--lazyllm",
  "meta": {
    "title": "LazyLLM: A  Low-code Development Tool For Building Multi-agent LLMs Applications.",
    "description": "Easiest and laziest way for  building multi-agent LLMs applications.",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T02:59:38.604Z",
    "dateModified": "2026-03-22T02:59:38.604Z",
    "keywords": [
