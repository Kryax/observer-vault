  "@type": "SolutionRecord",
  "@id": "ocp:github/k-dense-ai--claude-scientific-skills",
  "meta": {
    "title": "Claude Scientific Skills",
    "description": "A set of ready to use Agent Skills for research, science, engineering, analysis, finance and writing.",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T10:27:18.492Z",
    "dateModified": "2026-03-03T10:27:18.492Z",
