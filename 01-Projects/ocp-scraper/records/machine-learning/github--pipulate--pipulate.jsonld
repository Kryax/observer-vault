  "meta": {
    "title": "Pipulate: Local First AI SEO Software",
    "description": "Local First AI SEO Software on Nix, FastHTML & HTMX",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T21:01:39.996Z",
