  "meta": {
    "title": "dagger",
    "description": "Automation engine to build, test and ship any codebase. Runs locally, in CI, or directly in the cloud",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T00:14:04.049Z",
    "dateModified": "2026-03-03T00:14:04.049Z",
    "keywords": [
      "agents",
      "ai",
      "caching",
      "ci-cd",
      "containers",
      "continuous-deployment",
      "continuous-integration",
      "dag",
      "dagger",
      "devops",
      "docker",
      "graphql",
      "workflows"
    ],
    "license": "Apache-2.0"
  },
  "problemSolved": {
    "statement": "Dagger makes your software delivery *programmable*, *local-first*, *repeatable* and *observable*.",
