  "@id": "ocp:github/roboticslibrary--rl",
  "meta": {
    "title": "Robotics Library",
    "description": "The Robotics Library (RL) is a self-contained C++ library for rigid body kinematics and dynamics, motion planning, and control.",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T05:02:09.854Z",
    "dateModified": "2026-03-10T05:02:09.854Z",
