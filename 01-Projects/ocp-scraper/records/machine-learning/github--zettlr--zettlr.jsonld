  "@id": "ocp:github/zettlr--zettlr",
  "meta": {
    "title": "Zettlr",
    "description": "Your One-Stop Publication Workbench",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T21:01:46.725Z",
    "dateModified": "2026-03-10T21:01:46.725Z",
    "keywords": [
      "desktop",
      "docx",
