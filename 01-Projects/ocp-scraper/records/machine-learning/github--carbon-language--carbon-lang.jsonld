  "@id": "ocp:github/carbon-language--carbon-lang",
  "meta": {
    "title": "Carbon Language: <br/> An experimental successor to C++",
    "description": "Carbon Language's main repository: documents, design, implementation, and related tools. (NOTE: Carbon Language is experimental; see README)",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T05:30:14.797Z",
    "dateModified": "2026-03-22T05:30:14.797Z",
