  "problemSolved": {
    "statement": "authentik is an open-source Identity Provider (IdP) for modern SSO. It supports SAML, OAuth2/OIDC, LDAP, RADIUS, and more, designed for self-hosting from small labs to large production clusters.",
    "cynefinDomain": "complex"
  },
