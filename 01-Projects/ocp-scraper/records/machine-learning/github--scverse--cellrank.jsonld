  "meta": {
    "title": "CellRank 2: Unified fate mapping in multiview single-cell data",
    "description": "CellRank: dynamics from multi-view single-cell data",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T02:04:20.037Z",
