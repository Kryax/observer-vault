  "@id": "ocp:github/mlrun--mlrun",
  "meta": {
    "title": "Using MLRun",
    "description": "MLRun is an open source MLOps platform for quickly building and managing continuous ML applications across their lifecycle. MLRun integrates into your development and CI/CD environment and automates the delivery of production data, ML pipelines, and online applications.",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T05:37:09.000Z",
    "dateModified": "2026-03-22T05:37:09.000Z",
