  "@type": "SolutionRecord",
  "@id": "ocp:github/opengovern--opensecurity",
  "meta": {
    "title": "opensecurity",
    "description": "opensecurity: open-source security and compliance. See and secure your cloud, containers, code, networks, deployments, devices. Define your rules, get precise checks, fix gaps fast. Streamlined audits. No fluff.",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:52:47.427Z",
    "dateModified": "2026-03-11T04:52:47.427Z",
    "keywords": [
      "audit",
      "cloud-security",
      "compliance",
      "container-security",
      "cspm",
      "devsecops",
      "optimization",
      "oss",
      "policy-as-code",
      "security",
      "security-auditing-tool"
    ],
    "license": "NOASSERTION"
  },
  "problemSolved": {
    "statement": "* **🔍 Unified Visibility:** Effortlessly explore and analyze 1000+ assets (containers, cloud resources, and more) using intuitive SQL queries.\n* **⚙️ Customizable Controls:** Define compliance checks as SQL policies, leveraging the power of version control with Git.\n* **✅ Flexible Compliance:** Easily create custom, intricate compliance checks tailored to your specific needs.\n* **📈 Scalable Audits:** Efficiently manage thousands of checks across even the largest infrastructures.\n* **🔗 Broad Integrations:** Seamlessly connect with popular platforms like AWS, Azure, DigitalOcean, Linode, GitHub, and many more.",
    "cynefinDomain": "complex"
  },
  "domains": [
    "machine-learning",
    "security",
    "lang:typescript"
  ],
