  "meta": {
    "title": "GIS4WRF",
    "description": "QGIS toolkit 🧰 for pre- and post-processing 🔨, visualizing 🔍, and running simulations 💻 in the Weather Research and Forecasting (WRF) model 🌀",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:46:38.155Z",
