  "@type": "SolutionRecord",
  "@id": "ocp:github/scverse--scanpy",
  "meta": {
    "title": "Scanpy – Single-Cell Analysis in Python",
    "description": "Single-cell analysis in Python. Scales to >100M cells.",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T10:27:34.256Z",
    "dateModified": "2026-03-03T10:27:34.256Z",
    "keywords": [
