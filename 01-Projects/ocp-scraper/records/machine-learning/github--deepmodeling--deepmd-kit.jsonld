  "@id": "ocp:github/deepmodeling--deepmd-kit",
  "meta": {
    "title": "DeePMD-kit",
    "description": "A deep learning package for many-body potential energy representation and molecular dynamics",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:20:05.209Z",
    "dateModified": "2026-03-11T04:20:05.209Z",
