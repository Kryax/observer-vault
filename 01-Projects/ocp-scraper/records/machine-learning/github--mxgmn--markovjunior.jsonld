  "@id": "ocp:github/mxgmn--markovjunior",
  "meta": {
    "title": "MarkovJunior",
    "description": "Probabilistic language based on pattern matching and constraint propagation, 153 examples",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:24:09.002Z",
