  "meta": {
    "title": "⚡ AMPERE",
    "description": "Observable AI cognition in Kotlin Multiplatform. Every agent decision emits a structured event — peer into the glass brain.",
    "version": "1.0.0",
    "dateCreated": "2026-03-09T11:15:25.668Z",
