  "@id": "ocp:github/shaankhosla--repeater",
  "meta": {
    "title": "repeater",
    "description": "Spaced repetition, in your terminal",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T10:29:59.028Z",
    "dateModified": "2026-03-03T10:29:59.028Z",
