  "@type": "SolutionRecord",
  "@id": "ocp:github/remkop--picocli",
  "meta": {
    "title": "picocli - a mighty tiny command line interface",
    "description": "Picocli is a modern framework for building powerful, user-friendly, GraalVM-enabled command line apps with ease. It supports colors, autocompletion, subcommands, and more.  In 1 source file so apps can include as source & avoid adding a dependency. Written in Java, usable from Groovy, Kotlin, Scala, etc. ",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T08:44:39.120Z",
    "dateModified": "2026-03-03T08:44:39.120Z",
    "keywords": [
      "annotations",
      "ansi",
      "ansi-colors",
      "argument-parsing",
      "autocomplete",
      "bash-completion",
      "cli",
      "cli-framework",
      "command-line",
      "command-line-parser",
      "commandline",
      "completion",
