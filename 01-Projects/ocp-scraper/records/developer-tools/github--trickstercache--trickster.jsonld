    "title": "<img src=\"./docs/images/logos/trickster-logo.svg\" width=90 />&nbsp;&nbsp;&nbsp;&nbsp;<img src=\"./docs/images/logos/trickster-text.svg\" width=420 /> [![Follow on Twitter](https://img.shields.io/twitter/follow/trickstercache.svg?style=social&logo=twitter)](https://twitter.com/trickstercache)",
