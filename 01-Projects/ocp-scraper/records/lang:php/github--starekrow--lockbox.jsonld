  "@id": "ocp:github/starekrow--lockbox",
  "meta": {
    "title": "Lockbox",
    "description": "Encrypted storage with built-in key management facilities",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:46:49.085Z",
