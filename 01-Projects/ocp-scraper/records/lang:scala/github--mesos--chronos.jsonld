  "meta": {
    "title": "Chronos [![Build Status](https://travis-ci.org/mesos/chronos.svg?branch=master)](https://travis-ci.org/mesos/chronos)",
    "description": "Fault tolerant job scheduler for Mesos which handles dependencies and ISO8601 based schedules",
