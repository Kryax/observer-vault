      "alerting",
      "apm",
      "dashboard",
      "database-monitoring",
      "distributed-tracing",
      "ebpf",
      "metrics",
      "microservice",
      "monitoring",
      "observability",
      "prometheus",
      "service-map",
      "slo",
      "sre",
      "tracing"
    ],
    "license": "Apache-2.0"
  },
  "problemSolved": {
    "statement": "* Easily understand the status of your services, even when dealing with hundreds of them\n* Gain insight into application logs without the need to manually inspect each one\n* SLOs (Service Level Objectives) tracking",
    "cynefinDomain": "complex"
  },
