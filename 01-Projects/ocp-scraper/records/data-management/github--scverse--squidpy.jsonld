  "problemSolved": {
    "statement": "Squidpy is the scverse toolkit for scalable analysis and visualization of spatial molecular data.\nIt builds on [scanpy](https://scanpy.readthedocs.io/en/stable/) and [anndata](https://anndata.readthedocs.io/en/stable/), providing streamlined APIs for feature extraction, spatial statistics, and interactive exploration of tissue sections together with microscopy images.",
    "context": "Squidpy is the scverse toolkit for scalable analysis and visualization of spatial molecular data.\nIt builds on [scanpy](https://scanpy.readthedocs.io/en/stable/) and [anndata](https://anndata.readthedocs.io/en/stable/), providing streamlined APIs for feature extraction, spatial statistics, and interactive exploration of tissue sections together with microscopy images.\n\n![Squidpy overview](https://raw.githubusercontent.com/scverse/squidpy/main/docs/_static/img/figure1.png)",
    "cynefinDomain": "complex"
  },
