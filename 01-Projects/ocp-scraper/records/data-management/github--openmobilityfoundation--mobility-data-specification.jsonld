  "@id": "ocp:github/openmobilityfoundation--mobility-data-specification",
  "meta": {
    "title": "Mobility Data Specification",
    "description": "A data specification to enable right-of-way regulation, digital policy, geofencing, and two-way communication between mobility companies and public agencies worldwide for any regulated, shared vehicle.",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:50:34.462Z",
    "dateModified": "2026-03-11T04:50:34.462Z",
    "keywords": [
      "autonomous-vehicles",
      "bike-share",
      "carshare",
