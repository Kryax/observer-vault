  "@id": "ocp:github/redisearch--redisearch",
  "meta": {
    "title": "RediSearch",
    "description": "A query and indexing engine for Redis, providing secondary indexing, full-text search, vector similarity search and aggregations.",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:47:04.543Z",
    "dateModified": "2026-03-11T04:47:04.543Z",
