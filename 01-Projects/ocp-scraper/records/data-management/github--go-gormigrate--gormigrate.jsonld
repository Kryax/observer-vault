  "@id": "ocp:github/go-gormigrate--gormigrate",
  "meta": {
    "title": "Gormigrate",
    "description": "Minimalistic database migration helper for Gorm ORM",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T08:44:52.134Z",
