  "@type": "SolutionRecord",
  "@id": "ocp:github/dimitri--pgloader",
  "meta": {
    "title": "PGLoader",
    "description": "Migrate to PostgreSQL in a single command!",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T08:43:36.670Z",
    "dateModified": "2026-03-03T08:43:36.670Z",
