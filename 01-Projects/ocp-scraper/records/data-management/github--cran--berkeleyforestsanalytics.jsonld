  "@id": "ocp:github/cran--berkeleyforestsanalytics",
  "meta": {
    "title": "Berkeley Forests Analytics",
    "description": ":exclamation: This is a read-only mirror of the CRAN R package repository.  BerkeleyForestsAnalytics — Compute and Summarize Core Forest Metrics from Field Data. Homepage: https://github.com/kearutherford/BerkeleyForestsAnalytics  ",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T21:01:38.113Z",
