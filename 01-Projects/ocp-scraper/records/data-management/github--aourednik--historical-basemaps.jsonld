  "@id": "ocp:github/aourednik--historical-basemaps",
  "meta": {
    "title": "Historical boundaries of world countries and cultural regions",
    "description": "Collection of georeferenced boundaries of world countries and cultural regions for use in mapping historical data on global or continental scale",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:48:30.091Z",
    "dateModified": "2026-03-11T04:48:30.091Z",
    "keywords": [
