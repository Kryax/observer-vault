  "@id": "ocp:github/topoteretes--cognee",
  "meta": {
    "title": "cognee",
    "description": "Knowledge Engine for AI Agent Memory in 6 lines of code",
    "version": "1.0.0",
    "dateCreated": "2026-03-09T11:15:12.301Z",
