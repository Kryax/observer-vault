  "@id": "ocp:github/grantcarthew--node-rethinkdb-job-queue",
  "meta": {
    "title": "Introduction",
    "description": "A persistent job or task queue backed by RethinkDB.",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T08:43:37.144Z",
