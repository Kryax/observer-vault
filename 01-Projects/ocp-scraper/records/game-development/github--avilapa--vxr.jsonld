  "@id": "ocp:github/avilapa--vxr",
  "meta": {
    "title": "What is [vxr](https://github.com/avilapa/vxr)?",
    "description": "General purpose engine written in C++ with emphasis on materials rendering (PBR, clear coat, anisotropy, iridescence)",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T04:22:04.285Z",
    "dateModified": "2026-03-11T04:22:04.285Z",
