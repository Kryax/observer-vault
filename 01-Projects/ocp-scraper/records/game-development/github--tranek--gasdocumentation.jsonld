  "@id": "ocp:github/tranek--gasdocumentation",
  "meta": {
    "title": "GASDocumentation",
    "description": "My understanding of Unreal Engine 5's GameplayAbilitySystem plugin with a simple multiplayer sample project.",
    "version": "1.0.0",
    "dateCreated": "2026-03-22T06:57:24.129Z",
    "dateModified": "2026-03-22T06:57:24.129Z",
    "keywords": [],
