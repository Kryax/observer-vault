  "meta": {
    "title": "ArduPID",
    "description": "PID library for Arduinos",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T04:44:41.671Z",
    "dateModified": "2026-03-10T04:44:41.671Z",
    "keywords": [
