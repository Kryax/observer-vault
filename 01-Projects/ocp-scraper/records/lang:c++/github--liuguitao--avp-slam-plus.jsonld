  "@id": "ocp:github/liuguitao--avp-slam-plus",
  "meta": {
    "title": "AVP-SLAM-PLUS",
    "description": "An implementation of AVP-SLAM and some new contributions",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T05:00:44.612Z",
