  "@id": "ocp:github/okalachev--flix",
  "meta": {
    "title": "flix",
    "description": "Making an ESP32-based quadcopter from scratch",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T05:00:08.304Z",
    "dateModified": "2026-03-10T05:00:08.304Z",
    "keywords": [
