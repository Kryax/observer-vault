  "@id": "ocp:github/squirelo--emg-vr-adaptive-controller",
  "meta": {
    "title": "Electromyographic Quest VR Adaptive Controller 🦾🔌🎮👓🌟",
    "description": "DIY EMG VR Controller for Oculus Quest 2: low-cost, user-friendly electromyography-based control system with Arduino, MyoWare sensors, and 9gr servo motors. This beginner-oriented project offers a simple one-button setup to overcome input emulation limitations on Meta Quest and SteamVR devices, enabling virtual reality gaming for all #a11y",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T05:02:35.960Z",
    "dateModified": "2026-03-10T05:02:35.960Z",
    "keywords": [
      "adaptive",
      "adaptive-controller",
      "assistive-technology",
      "electromyography",
      "emg",
      "esp32",
      "esp8266",
      "human-computer-interaction",
      "playability",
      "virtual-reality"
    ],
    "license": "MIT"
  },
  "problemSolved": {
    "statement": "This project allows you to connect a MyoWare sensor to a standard electronic board (such as Arduino, ESP, etc.) to trigger small 9gr model motors directly attached to an Oculus Quest controller, simply fixed with hot glue.",
    "context": "This project allows you to connect a MyoWare sensor to a standard electronic board (such as Arduino, ESP, etc.) to trigger small 9gr model motors directly attached to an Oculus Quest controller, simply fixed with hot glue.\n\n![Nicolas Huchet and Valentin Squirelo tinkering adaptive controllers with Oculus Quest 2](https://i.imgur.com/3QhD80Ul.jpg)",
    "cynefinDomain": "complex"
  },
