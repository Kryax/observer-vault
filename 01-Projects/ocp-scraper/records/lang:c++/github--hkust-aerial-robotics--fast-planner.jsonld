  "@id": "ocp:github/hkust-aerial-robotics--fast-planner",
  "meta": {
    "title": "Fast-Planner",
    "description": "A Robust and Efficient Trajectory Planner for Quadrotors",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T05:03:04.595Z",
    "dateModified": "2026-03-10T05:03:04.595Z",
