  "@id": "ocp:github/pronenewbits--embedded_ekf_library",
  "meta": {
    "title": "Arduino_EKF_Library",
    "description": " A compact Extended Kalman Filter (EKF) library for real time embedded system (with template for Teensy4/Arduino and STM32CubeIDE)",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T05:00:28.693Z",
