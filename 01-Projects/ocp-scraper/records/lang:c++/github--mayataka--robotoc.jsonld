  "@type": "SolutionRecord",
  "@id": "ocp:github/mayataka--robotoc",
  "meta": {
    "title": "robotoc",
    "description": "Efficient optimal control solvers for robotic systems.",
    "version": "1.0.0",
    "dateCreated": "2026-03-06T05:57:58.999Z",
    "dateModified": "2026-03-06T05:57:58.999Z",
    "keywords": [
      "interior-point-method",
      "model-predictive-control",
      "motion-planning",
      "mpc",
      "numerical-optimal-control",
      "numerical-optimization",
      "optimal-control",
      "robotics",
      "switched-systems",
      "switching-time-optimization",
      "trajectory-optimization"
    ],
    "license": "BSD-3-Clause"
  },
  "problemSolved": {
    "statement": "- Direct multiple-shooting method based on the **lifted contact dynamics** / **inverse dynamics**.\n- Riccati recursion algorithm for **switching time optimization (STO)** problems and efficient **pure-state equality constraint handling**.\n- **Primal-dual interior point method** for inequality constraints.\n- Very fast computation of rigid body dynamics and its sensitivities thanks to [Pinocchio](https://github.com/stack-of-tasks/pinocchio).",
    "cynefinDomain": "complex"
  },
