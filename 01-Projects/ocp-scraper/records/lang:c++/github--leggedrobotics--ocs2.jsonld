  "@id": "ocp:github/leggedrobotics--ocs2",
  "meta": {
    "title": "OCS2 Toolbox",
    "description": "Optimal Control for Switched Systems",
    "version": "1.0.0",
    "dateCreated": "2026-03-06T05:57:54.637Z",
