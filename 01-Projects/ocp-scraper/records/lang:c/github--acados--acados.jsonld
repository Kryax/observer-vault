  "@id": "ocp:github/acados--acados",
  "meta": {
    "title": "acados",
    "description": "Fast and embedded solvers for nonlinear optimal control and nonlinear model predictive control",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T05:01:08.571Z",
    "dateModified": "2026-03-10T05:01:08.571Z",
