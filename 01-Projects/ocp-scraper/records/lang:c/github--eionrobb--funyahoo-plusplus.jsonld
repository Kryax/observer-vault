  "@id": "ocp:github/eionrobb--funyahoo-plusplus",
  "meta": {
    "title": "FunYahoo++",
    "description": "A replacement Yahoo prpl (protocol plugin) for Pidgin/libpurple",
    "version": "1.0.0",
    "dateCreated": "2026-03-11T02:03:55.057Z",
    "dateModified": "2026-03-11T02:03:55.057Z",
    "keywords": [
      "libpurple",
