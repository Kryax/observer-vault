  "@type": "SolutionRecord",
  "@id": "ocp:github/fluxninja--aperture",
  "meta": {
    "title": "🥷 FluxNinja Aperture",
    "description": "Rate limiting, caching, and request prioritization for modern workloads",
    "version": "1.0.0",
    "dateCreated": "2026-03-10T21:01:33.909Z",
    "dateModified": "2026-03-10T21:01:33.909Z",
    "keywords": [
      "caching",
      "cloud-native",
      "concurrency-limiter",
      "kubernetes",
      "llm",
      "microservices",
      "observability",
      "rate-limiter",
