  "@id": "ocp:github/node-cache--node-cache",
  "meta": {
    "title": "Simple and fast NodeJS internal caching.",
    "description": "a node internal (in-memory) caching module",
    "version": "1.0.0",
    "dateCreated": "2026-03-03T07:03:49.715Z",
