  "@id": "ocp:github/manuelrausch--statconfr",
  "meta": {
    "title": "1 The `statConfR` package for R",
    "description": "Development of an R package for metacognition researchers",
    "version": "1.0.0",
    "dateCreated": "2026-03-09T11:16:54.762Z",
