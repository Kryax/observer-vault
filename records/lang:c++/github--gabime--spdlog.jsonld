  "@id": "ocp:github/gabime--spdlog",
  "meta": {
    "title": "spdlog",
    "description": "Fast C++ logging library.",
    "version": "1.0.0",
    "dateCreated": "2026-03-13T11:21:17.372Z",
    "dateModified": "2026-03-13T11:21:17.372Z",
